{
  "name": "@fiber-pay/runtime",
  "version": "0.1.0-rc.7",
  "description": "Polling monitor and alert runtime for Fiber Network nodes",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "fiber",
    "monitor",
    "polling",
    "alerts",
    "runtime"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@biscuit-auth/biscuit-wasm": "^0.6.0",
    "@fiber-pay/sdk": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  }
}
