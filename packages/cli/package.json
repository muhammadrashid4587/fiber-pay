{
  "name": "@fiber-pay/cli",
  "version": "0.1.0-rc.7",
  "description": "Command-line tool for managing Fiber Network nodes",
  "type": "module",
  "bin": {
    "fiber-pay": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "error-codes.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ckb",
    "lightning",
    "fiber",
    "cli",
    "nervos"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fiber-pay/node": "workspace:*",
    "@fiber-pay/runtime": "workspace:*",
    "@fiber-pay/sdk": "workspace:*",
    "@inquirer/prompts": "^8.3.0",
    "commander": "^13.1.0",
    "yaml": "^2.8.2"
  }
}
