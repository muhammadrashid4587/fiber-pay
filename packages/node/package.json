{
  "name": "@fiber-pay/node",
  "version": "0.1.0",
  "description": "Fiber Network node binary management and process lifecycle",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
