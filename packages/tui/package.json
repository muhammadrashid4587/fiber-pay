{
  "name": "@fiber-pay/tui",
  "version": "0.1.0",
  "description": "Real-time terminal dashboard for Fiber runtime monitoring",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fiber-pay/runtime": "workspace:*",
    "@fiber-pay/sdk": "workspace:*",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ink-table": "^3.1.0",
    "react": "^18.3.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/ws": "^8.18.1"
  }
}
