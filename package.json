{
  "name": "fiber-pay-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "AI Agent Payment SDK for CKB Lightning Network (Fiber Network) - Monorepo",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter='!@fiber-pay/cli' build && pnpm --filter='@fiber-pay/cli' build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "test:run": "pnpm -r test:run",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "keywords": [
    "ckb",
    "lightning",
    "fiber",
    "payment",
    "ai-agent",
    "mcp",
    "cryptocurrency",
    "nervos",
    "monorepo"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
